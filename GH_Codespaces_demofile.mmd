classDiagram
    class LifeWorthContinuing {
        +inputs: InputCollection
        -_explicit_answer: string
        -_transform: AnswerTransformer
        +__init__(*inputs, answer=None, transform=None)
        +get_answer(): string
        +set_answer(answer): void
        +clear_inputs(): void
        +charge_to(storage: StorageAdapter, key: string): void
    }

    class InputCollection {
        -items: list
        +__init__(items=None)
        +add(item: string): void
        +extend(items: list): void
        +clear(): void
        +__iter__(): iterator
    }

    class AnswerTransformer {
        -func: callable
        +__init__(func=None)
        +set(func: callable): void
        +apply(text: string): string
    }

    class StorageAdapter {
        -storage: dict
        +__init__(storage=None)
        +save(key: string, payload: dict): void
        +load(key: string): dict
    }

    class Counselor {
        -lwc: LifeWorthContinuing
        +__init__(lwc: LifeWorthContinuing)
        +add_problem(problem: string): void
        +propose_answer(): void
        +save_session(storage: StorageAdapter, key: string): void
    }

    LifeWorthContinuing *-- InputCollection : has
    LifeWorthContinuing ..> AnswerTransformer : delegates to
    LifeWorthContinuing ..> StorageAdapter : persists to
    Counselor --> LifeWorthContinuing : manages
